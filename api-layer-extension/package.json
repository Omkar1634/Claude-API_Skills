{
  "name": "api-layer",
  "displayName": "API Layer",
  "description": "Scaffold a complete backend API project using AI — choose your framework, database, auth, and features through a guided wizard. Supports Claude, ChatGPT, Gemini, and Ollama.",
  "version": "0.1.0",
  "publisher": "api-layer",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Scaffolding",
    "Other"
  ],
  "keywords": [
    "api",
    "backend",
    "scaffold",
    "fastapi",
    "express",
    "claude",
    "chatgpt",
    "gemini",
    "ollama",
    "generator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Omkar1634/Claude-API_Skills"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "api-layer.createProject",
        "title": "API Layer: Create Project"
      },
      {
        "command": "api-layer.changeProvider",
        "title": "API Layer: Change AI Provider"
      },
      {
        "command": "api-layer.testConnection",
        "title": "API Layer: Test Connection"
      },
      {
        "command": "api-layer.selectOllamaModel",
        "title": "API Layer: Select Ollama Model"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "api-layer.createProject",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "API Layer",
      "properties": {
        "apiLayer.provider": {
          "type": "string",
          "enum": ["claude", "chatgpt", "gemini", "ollama"],
          "default": "",
          "description": "AI provider to use for code generation"
        },
        "apiLayer.ollamaModel": {
          "type": "string",
          "default": "codellama",
          "description": "Ollama model to use (only applies when provider is ollama)"
        },
        "apiLayer.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "openai": "^4.47.0",
    "@google/generative-ai": "^0.11.0"
  }
}
